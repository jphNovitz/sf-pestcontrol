<!DOCTYPE html>
<html lang="fr_BE">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Destruction de nids de guêpes et frelons{% endblock %}</title>
    {% if settings is defined and settings.faviconFilename %}
        <link rel="icon" href="{{ asset('uploads/brand/favicon/' ~ settings.faviconFilename) }}">
    {% else %}
        <link rel="icon"
              href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>GF</text></svg>">
    {% endif %}
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}
    {% endblock %}
</head>
<body class="min-h-dvh bg-base-100 text-base-content antialiased">
{% include '_base_parts/_header.html.twig' %}

<main>
    {% block body %}{% endblock %}
</main>

{% include '_base_parts/_footer.html.twig' %}

</body>
</html>
